{
  "schema_version": 2,
  "id": "frame-helm-movement-tracking-v1",
  "name": "Add Frame Helm movement tracking",
  "description": "Tracks token movement and commits movement actions at configured thresholds.",
  "backup": true,
  "allow_noop": false,

  "repository": {
    "require_git": true,
    "require_clean_targets": true,
    "require_clean_repository": false
  },

  "risk_acceptance": {
    "overwrite_files": false,
    "delete_files": false,
    "move_files": false,
    "change_dependencies": false,
    "modify_package_manifest": false
  },

  "limits": {
    "max_files_changed": 10,
    "max_total_added_bytes": 200000,
    "max_single_file_bytes": 500000,
    "allowed_roots": [
      "scripts",
      "styles",
      "templates",
      "dev_scripts"
    ]
  },

  "preconditions": [
    {
      "type": "file_exists",
      "file": "scripts/lancer-frame-helm.js"
    }
  ],

  "operations": [
    {
      "operation": "replace",
      "file": "scripts/lancer-frame-helm.js",
      "find": "const MODULE_ID = \"lancer-frame-helm\";",
      "replace": "const MODULE_ID = \"lancer-frame-helm\";\nconst MOVEMENT_TRACKING_ENABLED = true;",
      "expected_matches": 1
    },

    {
      "operation": "create",
      "file": "scripts/movement-tracker.js",
      "must_not_exist": true,
      "content": "export function recordTokenMovement() {\n  // Implementation\n}\n"
    }
  ],

  "postconditions": [
    {
      "type": "contains",
      "file": "scripts/lancer-frame-helm.js",
      "text": "MOVEMENT_TRACKING_ENABLED"
    },
    {
      "type": "file_exists",
      "file": "scripts/movement-tracker.js"
    }
  ],

  "validation": {
    "structural": true,
    "scan_dependencies": true,
    "link_node_modules": true,
    "timeout_seconds": 600,
    "commands": [
      ["npm", "run", "lint"],
      ["npm", "test"]
    ]
  }
}