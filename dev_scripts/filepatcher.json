nd failed\" in message:\n        likely_causes.extend(\n            [\n                \"The staged repository failed a configured lint, typecheck, test, or build command.\",\n                \"The textual patch applied successfully but produced an invalid repository state.\",\n            ]\n        )\n        recommended_fixes.extend(\n            [\n                \"Read the command output included in the error and repair the first underlying failure.\",\n                \"Check imports, exports, types, syntax, and test expectations affected by the patch.\",\n                \"Run the failing command manually after repairing the patch.\",\n            ]\n        )\n\n    elif \"timed out\" in message:\n        likely_causes.extend(\n            [\n                \"A validation command exceeded the configured timeout.\",\n                \"The command may be hanging, waiting for interaction, or performing excessive work.\",\n            ]\n        )\n        recommended_fixes.extend(\n            [\n                \"Run the validation command manually to determine whether it waits for input or hangs.\",\n                \"Use a non-interactive test or build command.\",\n                \"Increase timeout_seconds only when the command is known to complete safely.\",\n            ]\n        )\n\n    elif stage == \"postcondition_validation\":\n        likely_causes.extend(\n            [\n                \"The operations applied, but the staged repository does not satisfy the declared result contract.\",\n                \"A postcondition may be stale, incomplete, or aimed at the wrong file.\",\n            ]\n        )\n        recommended_fixes.extend(\n            [\n                \"Compare the staged result with each declared postcondition.\",\n                \"Correct the operations if the intended result was not produced.\",\n                \"Correct the postcondition only when the staged result is genuinely the intended state.\",\n            ]\n      